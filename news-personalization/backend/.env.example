# ─────────────────────────────────────────────
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://etuser:etpassword@postgres:5432/et_newsroom

# Redis
REDIS_URL=redis://redis:6379/0

# JWT Secret (change this to any random string in production)
SECRET_KEY=supersecretkey123changeme
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ─── FREE Gemini API ───────────────────────────────────────────
# Get your FREE key here → https://aistudio.google.com/app/apikey
# Click "Create API Key" — no credit card needed!
GEMINI_API_KEY=your_gemini_api_key_here

# ─── News Settings ────────────────────────────────────────────
NEWS_FETCH_INTERVAL_MINUTES=15   # how often Celery fetches fresh news
MAX_ARTICLES_PER_FEED=10         # articles per user in their feed
