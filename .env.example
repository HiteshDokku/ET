# ─────────────────────────────────────────────
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# ─── Groq (ALL LLM Tasks) ────────────────────────────────────
# Uses gpt-oss-120b for complex reasoning, llama-3-70b for workers
GROQ_API_KEY=your_groq_api_key_here

# ─── Video Studio ────────────────────────────────────────────
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
PEXELS_API_KEY=your_pexels_api_key_here

# ─── Clerk Auth ──────────────────────────────────────────────
CLERK_PUBLISHABLE_KEY=pk_test_your_key_here
CLERK_SECRET_KEY=sk_test_your_key_here

# ─── Database (auto-set by docker-compose) ───────────────────
DATABASE_URL=postgresql+asyncpg://etuser:etpassword@postgres:5432/et_newsroom
REDIS_URL=redis://redis:6379/0

# ─── JWT (for internal use) ──────────────────────────────────
SECRET_KEY=supersecretkey123changeme
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ─── News Settings ───────────────────────────────────────────
NEWS_FETCH_INTERVAL_MINUTES=15
MAX_ARTICLES_PER_FEED=10
